# ==========================================================
# Portal Financeiro Comercial - variáveis compartilhadas (Docker Compose)
# Copie para .env e ajuste. NUNCA versione o .env real.
# ==========================================================

# ---- PostgreSQL ----
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal_dev_password
POSTGRES_DB=portal_financeiro
POSTGRES_PORT=5432

# ---- Backend ----
BACKEND_PORT=3000
# String de conexão usada pelo Prisma dentro do compose (host = nome do serviço "db")
DATABASE_URL=postgresql://portal:portal_dev_password@db:5432/portal_financeiro?schema=public
NODE_ENV=development

# CORS / Cookies (produção: use HTTPS e domínio base, ex. .farmaciaestrela.com.br)
FRONTEND_URL=http://localhost:5173
COOKIE_DOMAIN=localhost

# ---- Autenticação ----
# Gere segredos fortes em produção (ex.: openssl rand -base64 48)
JWT_SECRET=troque-este-segredo-de-access-token
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=troque-este-segredo-de-refresh-token
REFRESH_TOKEN_EXPIRES_IN=7d

# Diretório de uploads (montado em volume persistente no Coolify)
UPLOADS_DIR=/data/uploads

# Recebimentos: false = exige confirmação ADMIN (recomendado em produção)
RECEIPTS_AUTO_CONFIRM=false

# Rate limit global (req/min por IP). Aumente temporariamente para scripts de teste locais.
THROTTLE_LIMIT=100

# ---- Frontend ----
FRONTEND_PORT=5173
# URL pública da API acessível pelo navegador (build-time do Vite)
VITE_API_URL=http://localhost:3000
