# ==========================================================
# Backend (NestJS) - variáveis de ambiente
# Copie para backend/.env e ajuste. NUNCA versione o .env real.
# ==========================================================

NODE_ENV=development
BACKEND_PORT=3000

# Conexão Prisma/PostgreSQL.
# Em desenvolvimento local (sem Docker), use host=localhost.
# Dentro do Docker Compose, use host=db (nome do serviço).
DATABASE_URL=postgresql://portal:portal_dev_password@localhost:5432/portal_financeiro?schema=public

# CORS - URL exata do frontend (necessário com credentials/cookies)
FRONTEND_URL=http://localhost:5173

# Cookies. Em Coolify com subdomínios use o domínio base: .seu-dominio.com
COOKIE_DOMAIN=localhost

# ---- Autenticação (Fase 2) ----
# Gere segredos fortes em produção (ex.: openssl rand -base64 48)
JWT_SECRET=troque-este-segredo-de-access-token
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=troque-este-segredo-de-refresh-token
REFRESH_TOKEN_EXPIRES_IN=7d

# Uploads persistentes (volume Docker)
UPLOADS_DIR=/data/uploads

# Rate limit global (requisições por minuto por IP)
THROTTLE_LIMIT=100

# ---- Recebimentos (Fase 6) ----
# Se true, recebimentos novos já entram como CONFIRMADO (afetam saldo imediatamente).
# Se false (recomendado), entram como PENDENTE_CONFIRMACAO e só afetam o saldo
# após confirmação por um ADMIN.
RECEIPTS_AUTO_CONFIRM=false
