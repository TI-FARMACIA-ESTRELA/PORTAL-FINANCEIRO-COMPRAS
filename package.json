{
  "name": "portal-financeiro-comercial",
  "version": "0.1.0",
  "private": true,
  "description": "Portal Financeiro Comercial - Farmácia Estrela (monorepo)",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "lint:frontend": "npm run lint --workspace frontend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace backend",
    "prisma:seed": "npm run prisma:seed --workspace backend",
    "test:e2e": "npm run test:e2e --workspace backend"
  },
  "engines": {
    "node": ">=20"
  }
}
