# ==========================================================
# Frontend (Vite) - variáveis de ambiente
# Copie para frontend/.env e ajuste. NUNCA versione o .env real.
# Apenas variáveis prefixadas com VITE_ são expostas ao client.
# ==========================================================

# URL base da API NestJS (sem /api — o client adiciona automaticamente)
# Desenvolvimento local: http://localhost:3000
# Produção (Coolify): https://api.seu-dominio.com
VITE_API_URL=http://localhost:3000
